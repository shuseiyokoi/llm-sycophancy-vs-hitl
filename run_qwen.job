#!/bin/bash

#SBATCH --job-name=qwen_sycophancy
#SBATCH --time=8:00:00
#SBATCH --partition=gpu
#SBATCH --account=jonmay_1426
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=4
#SBATCH --mem-per-cpu=8GB

# ---- adjust these paths to where things live on Discovery ----
REPO=/project2/jonmay_1426/syokoi/llm-sycophancy-emotional-framing
VENV=/project2/jonmay_1426/syokoi/env_general
# path to a CUDA build of llama.cpp's server binary
export LLAMA_SERVER=/project2/jonmay_1426/syokoi/llama.cpp/build/bin/llama-server

source "$VENV/bin/activate"
module load cuda

# call_qwen.py starts and stops the llama.cpp server itself,
# once per model in config.LOCAL_MODELS
cd "$REPO/src/call_models"
python call_qwen.py
