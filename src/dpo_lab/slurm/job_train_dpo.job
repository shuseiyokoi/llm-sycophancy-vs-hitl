#!/bin/bash
# NOT THE DEFAULT PATH — held in reserve. Training runs on the desktop PC;
# only submit this to Discovery if that is explicitly decided later.
#
# DPO training for one (arm, fraction) cell on Discovery.
# Usage:  sbatch job_train_dpo.job human 0.25
#         sbatch job_train_dpo.job ai 1.0

#SBATCH --job-name=dpo_lab
#SBATCH --time=12:00:00
#SBATCH --partition=gpu
#SBATCH --account=jonmay_1426
#SBATCH --gres=gpu:a100:1
#SBATCH --cpus-per-task=4
#SBATCH --mem-per-cpu=16GB

# ---- adjust these paths to where things live on Discovery ----
REPO=/project2/jonmay_1426/syokoi/llm-sycophancy-vs-hitl
VENV=/project2/jonmay_1426/syokoi/env_general

ARM=${1:?usage: sbatch job_train_dpo.job <human|ai> <fraction>}
FRACTION=${2:?usage: sbatch job_train_dpo.job <human|ai> <fraction>}

source "$VENV/bin/activate"
module load cuda

cd "$REPO/src/dpo_lab"
python train_dpo.py --arm "$ARM" --fraction "$FRACTION"
